generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id
  email        String?       @unique
  firstName    String?
  lastName     String?
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workflows    Workflow[]
  workflowRuns WorkflowRun[]
}

model Workflow {
  id        String   @id @default(uuid())
  userId    String
  name      String
  nodes     Json
  edges     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model WorkflowRun {
  id          Int      @id @default(autoincrement())
  userId      String
  timestamp   DateTime @default(now())
  scope       String
  scopeLabel  String
  status      String
  durationMs  Int

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeResults NodeResult[]

  @@index([userId, timestamp])
}

model NodeResult {
  id          Int      @id @default(autoincrement())
  runId       Int
  nodeId      String
  nodeName    String
  status      String
  durationMs  Int
  output      String?
  error       String?

  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}
