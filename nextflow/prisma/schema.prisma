generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkflowRun {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  scope       String
  scopeLabel  String
  status      String
  durationMs  Int

  nodeResults NodeResult[]
}

model NodeResult {
  id          Int      @id @default(autoincrement())
  runId       Int
  nodeId      String
  nodeName    String
  status      String
  durationMs  Int
  output      String?
  error       String?

  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}
